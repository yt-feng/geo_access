{
  "name": "geo-access-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "monitor:login": "node monitor/playwright_monitor.js login",
    "monitor:unlock": "node monitor/playwright_monitor.js unlock",
    "monitor:once": "node monitor/playwright_monitor.js once",
    "monitor:yuanbao": "GEO_MONITOR_PLATFORMS=yuanbao node monitor/playwright_monitor.js once",
    "monitor:yuanbao:loop": "GEO_MONITOR_PLATFORMS=yuanbao node monitor/playwright_monitor.js loop",
    "monitor:matrix": "GEO_MONITOR_PLATFORMS=deepseek,yuanbao node monitor/playwright_monitor.js matrix",
    "intent:minimed:prepare": "node monitor/intention_lab.js prepare-minimed",
    "monitor:minimed:yuanbao": "GEO_MONITOR_PLATFORMS=yuanbao GEO_MONITOR_RUN_LABEL=minimed_intent_lab GEO_PROMPT_MATRIX_FILE=monitor_runs/minimed_intent_lab/prompt_matrix.txt GEO_INTENT_SPEC_FILE=monitor_runs/minimed_intent_lab/intent_spec.json node monitor/playwright_monitor.js matrix",
    "intent:minimed:score": "node monitor/intention_lab.js score",
    "analyze:geo": "node monitor/analyze_geo.js",
    "dashboard:matrix": "node monitor/build_dashboard.js",
    "monitor:loop": "node monitor/playwright_monitor.js loop"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  }
}
